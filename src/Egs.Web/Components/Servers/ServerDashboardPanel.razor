@using Egs.Agent.Abstractions.Status
@using Egs.Contracts.Servers
@using Egs.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@inject ServerApiClient Api
@inject IConfiguration Configuration
@implements IAsyncDisposable

@if (ServerId is null)
{
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h6">Select a server</MudText>
        <MudText Typo="Typo.body2">Choose a server from the list to load its dashboard.</MudText>
    </MudPaper>
}
else if (_details is null)
{
    <MudPaper Class="pa-6">
        <MudProgressCircular Indeterminate="true" />
    </MudPaper>
}
else
{
    <MudStack Spacing="3">
        <MudPaper Class="pa-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h4">@_details.Name</MudText>
                    <MudText Typo="Typo.body2">
                        Game: @_details.GameKey | Node: @_details.NodeName
                    </MudText>
                </div>

                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                    <MudChip T="string"
                             Color="@GetStatusColor(_details.Status)"
                             Variant="Variant.Filled">
                        @_details.Status
                    </MudChip>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="InstallAsync">
                        Install
                    </MudButton>


                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="StartAsync">
                        Start
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="RestartAsync">
                        Restart
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="StopAsync">
                        Stop
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="UninstallAsync">
                        Uninstall
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteAsync">
                        Delete
                    </MudButton>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">
                        Save Settings
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <MudAlert Severity="Severity.Success">@_message</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }

        <MudGrid Spacing="3">
            <MudItem xs="12" md="7">
                <ServerSettingsTabs Details="_details" />
            </MudItem>

            <MudItem xs="12" md="5">
                @if (PrimaryMetadata.Count > 0)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">Connection Info</MudText>

                        @foreach (var item in PrimaryMetadata)
                        {
                            <MudPaper Class="pa-3 mb-2" Outlined="true">
                                <MudText Typo="Typo.caption">@item.Label</MudText>
                                <MudText Typo="Typo.h5">@item.Value</MudText>
                            </MudPaper>
                        }
                    </MudPaper>
                }

                @if (SecondaryMetadata.Count > 0)
                {
                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">Plugin Details</MudText>

                        <MudStack Spacing="1">
                            @foreach (var item in SecondaryMetadata)
                            {
                                <MudText Typo="Typo.body2">@item.Label: @item.Value</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                }

                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Quick Status</MudText>

                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body2">Status: @_details.Status</MudText>
                        <MudText Typo="Typo.body2">Node: @_details.NodeName</MudText>

                        @if (ShowGenericAddressInfo)
                        {
                            <MudText Typo="Typo.body2">IP: @(_details.IpAddress ?? "-")</MudText>
                            <MudText Typo="Typo.body2">Port: @FormatInt(_details.Port)</MudText>
                            <MudText Typo="Typo.body2">Query Port: @FormatInt(_details.QueryPort)</MudText>
                        }

                        <MudText Typo="Typo.body2">PID: @(_details.ProcessId?.ToString() ?? "-")</MudText>
                        <MudText Typo="Typo.body2">Uptime: @FormatUptime(_details.StartedUtc)</MudText>
                    </MudStack>
                </MudPaper>

                <ServerConsolePanel Lines="ConsoleLines" />
            </MudItem>
        </MudGrid>
    </MudStack>
}

@code {
    [Parameter] public Guid? ServerId { get; set; }
    [Parameter] public IReadOnlyList<string> ConsoleLines { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<Guid> OnServerDeleted { get; set; }
    [Parameter] public EventCallback OnRefreshRequested { get; set; }

    private ServerDetailsDto? _details;
    private Guid? _loadedServerId;
    private HubConnection? _statusHub;
    private PeriodicTimer? _uptimeTimer;
    private CancellationTokenSource? _uptimeCts;
    private Task? _uptimeTask;

    private string? _error;
    private string? _message;
    private IReadOnlyList<ServerMetadataItemDto> PrimaryMetadata =>
    _details?.PluginMetadata.Where(x => x.Highlight).ToList() ?? [];

    private IReadOnlyList<ServerMetadataItemDto> SecondaryMetadata =>
        _details?.PluginMetadata.Where(x => !x.Highlight).ToList() ?? [];

    private bool ShowGenericAddressInfo =>
        PrimaryMetadata.Count == 0;
    protected override async Task OnInitializedAsync()
    {
        _uptimeCts = new CancellationTokenSource();
        _uptimeTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _uptimeTask = Task.Run(async () =>
        {
            try
            {
                while (await _uptimeTimer.WaitForNextTickAsync(_uptimeCts.Token))
                {
                    if (_details is not null && _details.StartedUtc is not null)
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch (OperationCanceledException)
            {
            }
        });
    }

    protected override async Task OnParametersSetAsync()
    {
        await EnsureStatusHubConnectedAsync();

        if (ServerId is null)
        {
            _details = null;
            _loadedServerId = null;
            return;
        }

        if (_loadedServerId != ServerId)
        {
            _loadedServerId = ServerId;
            _error = null;
            _message = null;

            await LoadDetailsAsync();
        }
    }

    private async Task EnsureStatusHubConnectedAsync()
    {
        if (_statusHub is not null)
            return;

        var apiBase = Configuration["ApiBaseUrl"] ?? "https://localhost:7110/";
        var statusHubUrl = new Uri(new Uri(apiBase), "hubs/server-status");

        _statusHub = new HubConnectionBuilder()
            .WithUrl(statusHubUrl)
            .WithAutomaticReconnect()
            .Build();

        _statusHub.On<ServerStatusChangedMessage>("ServerStatusChanged", async message =>
        {
            if (_loadedServerId is null || message.ServerId != _loadedServerId.Value)
                return;
            if (string.Equals(message.Status, "Deleted", StringComparison.OrdinalIgnoreCase))
            {
                var deletedId = message.ServerId;

                _details = null;
                _loadedServerId = null;

                if (OnRefreshRequested.HasDelegate)
                    await OnRefreshRequested.InvokeAsync();

                if (OnServerDeleted.HasDelegate)
                    await OnServerDeleted.InvokeAsync(deletedId);

                await InvokeAsync(StateHasChanged);
                return;
            }
            await LoadDetailsAsync();
            await InvokeAsync(StateHasChanged);
        });

        await _statusHub.StartAsync();
    }

    private async Task LoadDetailsAsync()
    {
        if (_loadedServerId is null)
        {
            _details = null;
            return;
        }

        _details = await Api.GetServerDetailsAsync(_loadedServerId.Value);

        if (_details is null)
        {
            _loadedServerId = null;
        }
    }

    private async Task SaveAsync()
    {
        if (_details is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.SaveServerSettingsAsync(_details.Id, _details.Settings);
            await LoadDetailsAsync();
            _message = "Settings saved.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task InstallAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.InstallAsync(_loadedServerId.Value);
            await LoadDetailsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
    private async Task UninstallAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.UninstallAsync(_loadedServerId.Value);
            await LoadDetailsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
    private async Task StartAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.StartAsync(_loadedServerId.Value);
            await LoadDetailsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task StopAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.StopAsync(_loadedServerId.Value);
            await LoadDetailsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task RestartAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        try
        {
            await Api.RestartAsync(_loadedServerId.Value);
            await LoadDetailsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
    private async Task DeleteAsync()
    {
        if (_loadedServerId is null)
            return;

        _error = null;
        _message = null;

        var deletedId = _loadedServerId.Value;

        try
        {
            await Api.DeleteAsync(deletedId);

            _details = null;
            _loadedServerId = null;
            _message = "Delete queued.";

            if (OnRefreshRequested.HasDelegate)
                await OnRefreshRequested.InvokeAsync();

            if (OnServerDeleted.HasDelegate)
                await OnServerDeleted.InvokeAsync(deletedId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private static string FormatInt(int? value)
        => value?.ToString() ?? "-";

    private static string FormatUptime(DateTimeOffset? startedUtc)
    {
        if (startedUtc is null)
            return "-";

        var uptime = DateTimeOffset.UtcNow - startedUtc.Value;
        if (uptime.TotalSeconds < 0)
            return "-";

        if (uptime.TotalDays >= 1)
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h {uptime.Minutes}m {uptime.Seconds}s";

        if (uptime.TotalHours >= 1)
            return $"{uptime.Hours}h {uptime.Minutes}m {uptime.Seconds}s";

        if (uptime.TotalMinutes >= 1)
            return $"{uptime.Minutes}m {uptime.Seconds}s";

        return $"{uptime.Seconds}s";
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Running" => Color.Success,
        "Starting" => Color.Info,
        "Restarting" => Color.Warning,
        "Stopping" => Color.Warning,
        "Stopped" => Color.Default,
        _ => Color.Default
    };

    public async ValueTask DisposeAsync()
    {
        try
        {
            _uptimeCts?.Cancel();
        }
        catch
        {
        }

        _uptimeTimer?.Dispose();
        _uptimeCts?.Dispose();

        if (_uptimeTask is not null)
        {
            try
            {
                await _uptimeTask;
            }
            catch
            {
            }
        }

        if (_statusHub is not null)
        {
            await _statusHub.DisposeAsync();
        }
    }
}