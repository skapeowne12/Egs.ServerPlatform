@if (!string.IsNullOrWhiteSpace(Title))
{
    <MudText Typo="Typo.h6" Class="mb-2">@Title</MudText>
}

<MudPaper Class="@PaperClass"
          Style="@($"height: {Height}; overflow-y: auto; font-family: Consolas, monospace; {Style}")">
    @if (Lines.Count == 0)
    {
        <MudText Typo="Typo.body2">No console lines yet.</MudText>
    }
    else
    {
        @foreach (var line in Lines)
        {
            <div>@line</div>
        }
    }
</MudPaper>

@code {
    [Parameter] public IReadOnlyList<string> Lines { get; set; } = Array.Empty<string>();
    [Parameter] public string Title { get; set; } = "Console";
    [Parameter] public string Height { get; set; } = "500px";
    [Parameter] public string PaperClass { get; set; } = "pa-4";
    [Parameter] public string Style { get; set; } = string.Empty;
}