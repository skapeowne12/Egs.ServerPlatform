+
+                    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="StopAsync">
+                        Stop
+                    </MudButton>
+
+                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">
