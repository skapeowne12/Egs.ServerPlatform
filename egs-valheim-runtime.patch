+
+    private ServerDetailsDto? _details;
+    private Guid? _loadedServerId;
+    private HubConnection? _statusHub;
+
+    private string? _error;
+    private string? _message;
+
+    protected override async Task OnParametersSetAsync()
+    {
+        await EnsureStatusHubConnectedAsync();
+
+        if (ServerId is null)
+        {
+            _details = null;
+            _loadedServerId = null;
+            return;
+        }
+
+        if (_loadedServerId != ServerId)
+        {
+            _loadedServerId = ServerId;
+            _error = null;
+            _message = null;
+
+            await LoadDetailsAsync();
+        }
+    }
+
+    private async Task EnsureStatusHubConnectedAsync()
+    {
+        if (_statusHub is not null)
+            return;
+
+        var apiBase = Configuration["ApiBaseUrl"] ?? "https://localhost:7110/";
+        var statusHubUrl = new Uri(new Uri(apiBase), "hubs/server-status");
+
+        _statusHub = new HubConnectionBuilder()
+            .WithUrl(statusHubUrl)
+            .WithAutomaticReconnect()
+            .Build();
+
+        _statusHub.On<ServerStatusChangedMessage>("ServerStatusChanged", async message =>
+        {
+            if (_details is null || _loadedServerId is null || message.ServerId != _loadedServerId.Value)
+                return;
+
+            _details.Status = message.Status;
+            _details.ProcessId = message.ProcessId;
+
+            await InvokeAsync(StateHasChanged);
+        });
+
+        await _statusHub.StartAsync();
+    }
+
+    private async Task LoadDetailsAsync()
+    {
+        if (_loadedServerId is null)
+        {
+            _details = null;
+            return;
+        }
+
+        _details = await Api.GetServerDetailsAsync(_loadedServerId.Value);
+    }
+
+    private async Task SaveAsync()
+    {
+        if (_details is null)
+            return;
+
+        _error = null;
+        _message = null;
+
+        try
+        {
+            await Api.SaveServerSettingsAsync(_details.Id, _details.Settings);
+            _message = "Settings saved.";
+        }
+        catch (Exception ex)
+        {
+            _error = ex.Message;
+        }
+    }
+
+    private async Task InstallAsync()
+    {
+        if (_loadedServerId is null)
+            return;
+
+        _error = null;
+        _message = null;
+
+        try
+        {
+            await Api.InstallAsync(_loadedServerId.Value);
+        }
+        catch (Exception ex)
+        {
+            _error = ex.Message;
+        }
+    }
+
+    private async Task StartAsync()
+    {
+        if (_loadedServerId is null)
+            return;
+
+        _error = null;
+        _message = null;
+
+        try
+        {
+            await Api.StartAsync(_loadedServerId.Value);
+        }
+        catch (Exception ex)
+        {
+            _error = ex.Message;
+        }
+    }
+
+    private async Task StopAsync()
+    {
+        if (_loadedServerId is null)
+            return;
+
+        _error = null;
+        _message = null;
+
+        try
+        {
+            await Api.StopAsync(_loadedServerId.Value);
+        }
+        catch (Exception ex)
+        {
+            _error = ex.Message;
+        }
+    }
+
+    private async Task RestartAsync()
+    {
+        if (_loadedServerId is null)
+            return;
+
+        _error = null;
+        _message = null;
+
+        try
+        {
+            await Api.RestartAsync(_loadedServerId.Value);
+        }
+        catch (Exception ex)
+        {
+            _error = ex.Message;
+        }
+    }
+
+    private static Color GetStatusColor(string status) => status switch
+    {
+        "Running" => Color.Success,
+        "Starting" => Color.Info,
+        "Restarting" => Color.Warning,
+        "Stopping" => Color.Warning,
+        "Stopped" => Color.Default,
+        _ => Color.Default
+    };
+
+    public async ValueTask DisposeAsync()
+    {
+        if (_statusHub is not null)
+        {
+            await _statusHub.DisposeAsync();
+        }
+    }
 }
